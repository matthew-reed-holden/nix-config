! Catppuccin Mocha for legacy XWayland apps (xterm, etc.)
! Static palette — update by hand if you want wallpaper-driven; not
! many apps still consume .Xresources so kept simple.

*background:  #1e1e2e
*foreground:  #cdd6f4
*cursorColor: #f5e0dc

! 16 ANSI colors
*color0:  #45475a
*color1:  #f38ba8
*color2:  #a6e3a1
*color3:  #f9e2af
*color4:  #89b4fa
*color5:  #f5c2e7
*color6:  #94e2d5
*color7:  #bac2de
*color8:  #585b70
*color9:  #f38ba8
*color10: #a6e3a1
*color11: #f9e2af
*color12: #89b4fa
*color13: #f5c2e7
*color14: #94e2d5
*color15: #a6adc8

Xft.dpi:       96
Xft.antialias: true
Xft.hinting:   true
Xft.hintstyle: hintslight
Xft.rgba:      rgb
